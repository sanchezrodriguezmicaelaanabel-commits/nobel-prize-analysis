{"cells":[{"source":"The Nobel Prize has been among the most prestigious international awards since 1901. Each year, awards are bestowed in chemistry, literature, physics, physiology or medicine, economics, and peace. In addition to the honor, prestige, and substantial prize money, the recipient also gets a gold medal with an image of Alfred Nobel (1833 - 1896), who established the prize.\n\n![](Nobel_Prize.png)\n\nThe Nobel Foundation has made a dataset available of all prize winners from the outset of the awards from 1901 to 2023. The dataset used in this project is from the Nobel Prize API and is available in the `nobel.csv` file in the `data` folder.\n\nIn,"id":"db5bd2ce-918a-4f7d-a927-a3ea74c4b456","cell_type":"markdown","metadata":{"collapsed":false,"jupyter":{"outputs_hidden":false,"source_hidden":false}}},{"source":"import pandas as pd\nimport seaborn as sns\nimport numpy as np\nimport matplotlib.pyplot as plt\n\nnobel= pd.read_csv(\"data/nobel.csv\")\ntop_gender= nobel[\"sex\"].value_counts().index[0]\ntop_country= nobel[\"birth_country\"].value_counts().index[0]\n\nnobel[\"usa_born\"]= nobel[\"birth_country\"] == \"United States of America\"\nnobel[\"decade\"]= (nobel[\"year\"]//10)*10\nratio= nobel.groupby(\"decade\")[\"usa_born\"].mean()\nratio_decade= ratio.sort_values(ascending=False)\nmax_decade_usa= ratio_decade.index[0]\ng= sns.relplot(x=\"decade\", y=\"usa_born\", data=nobel, kind=\"line\")\ng.fig.suptitle(\"Ratio Nobel Prize Winners\", y=1.03)\nplt.show()\n\nnobel[\"Female_Winners\"]= nobel[\"sex\"] == \"Female\"\nnobel[\"decade\"]= (nobel[\"year\"]//10)*10\nFemale_Ratio= nobel.groupby([\"decade\", \"category\"])[\"Female_Winners\"].mean()\nRatio_sorted= Female_Ratio.sort_values(ascending=False)\nFemale_decade= Ratio_sorted.index[0]\nmax_female_dict={2020:\"Literature\"}\ng= sns.relplot(x=\"decade\", y=\"Female_Winners\", data=nobel, kind=\"line\", col=\"category\")\ng.fig.suptitle(\"Female Laureates\")\nplt.show()\n\nWoman_win= nobel[nobel[\"sex\"] == \"Female\"]\nwoman_order= Woman_win.sort_values(\"year\")\nfirst_woman_name= woman_order[\"full_name\"].iloc[0]\nfirst_woman_category= woman_order[\"category\"].iloc[0]\n\nWinners= nobel[\"full_name\"].value_counts()\nMost_win= Winners[Winners >= 2]\nrepeat_list= list(Most_win.index)\nprint(repeat_list)\n\n\n\n","id":"11fd5946-7bd1-495c-aa7f-ff6e7e4a350b","cell_type":"code","outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 500x500 with 1 Axes>","image/png":""},"metadata":{"image/png":{"width":488,"height":518}}},{"output_type":"display_data","data":{"text/plain":"<Figure size 3000x500 with 6 Axes>","image/png":""},"metadata":{"image/png":{"width":2988,"height":493}}},{"output_type":"stream","name":"stdout","text":"['Comité international de la Croix Rouge (International Committee of the Red Cross)', 'Linus Carl Pauling', 'John Bardeen', 'Frederick Sanger', 'Marie Curie, née Sklodowska', 'Office of the United Nations High Commissioner for Refugees (UNHCR)']\n"}],"metadata":{"executionCancelledAt":null,"executionTime":2325,"lastExecutedAt":1780515134588,"lastExecutedByKernel":"76e59bab-00c7-496e-bbfd-818e1a32e561","lastScheduledRunId":null,"lastSuccessfullyExecutedCode":"import pandas as pd\nimport seaborn as sns\nimport numpy as np\nimport matplotlib.pyplot as plt\n\nnobel= pd.read_csv(\"data/nobel.csv\")\ntop_gender= nobel[\"sex\"].value_counts().index[0]\ntop_country= nobel[\"birth_country\"].value_counts().index[0]\n\nnobel[\"usa_born\"]= nobel[\"birth_country\"] == \"United States of America\"\nnobel[\"decade\"]= (nobel[\"year\"]//10)*10\nratio= nobel.groupby(\"decade\")[\"usa_born\"].mean()\nratio_decade= ratio.sort_values(ascending=False)\nmax_decade_usa= ratio_decade.index[0]\ng= sns.relplot(x=\"decade\", y=\"usa_born\", data=nobel, kind=\"line\")\ng.fig.suptitle(\"Ratio Nobel Prize Winners\", y=1.03)\nplt.show()\n\nnobel[\"Female_Winners\"]= nobel[\"sex\"] == \"Female\"\nnobel[\"decade\"]= (nobel[\"year\"]//10)*10\nFemale_Ratio= nobel.groupby([\"decade\", \"category\"])[\"Female_Winners\"].mean()\nRatio_sorted= Female_Ratio.sort_values(ascending=False)\nFemale_decade= Ratio_sorted.index[0]\nmax_female_dict={2020:\"Literature\"}\ng= sns.relplot(x=\"decade\", y=\"Female_Winners\", data=nobel, kind=\"line\", col=\"category\")\ng.fig.suptitle(\"Female Laureates\")\nplt.show()\n\nWoman_win= nobel[nobel[\"sex\"] == \"Female\"]\nwoman_order= Woman_win.sort_values(\"year\")\nfirst_woman_name= woman_order[\"full_name\"].iloc[0]\nfirst_woman_category= woman_order[\"category\"].iloc[0]\n\nWinners= nobel[\"full_name\"].value_counts()\nMost_win= Winners[Winners >= 2]\nrepeat_list= list(Most_win.index)\nprint(repeat_list)\n\n\n\n","outputsMetadata":{"0":{"height":101,"type":"stream"},"2":{"height":80,"type":"stream"},"3":{"height":101,"type":"stream"}},"collapsed":false,"jupyter":{"outputs_hidden":false,"source_hidden":false}},"execution_count":46}],"metadata":{"language_info":{"name":"python","version":"3.8.10","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kernelspec":{"display_name":"Python 3 (ipykernel)","language":"python","name":"python3"},"editor":"DataCamp Workspace"},"nbformat":4,"nbformat_minor":5}
